{
  "compilerOptions": {
    "target": "ES2023",
    "module": "esnext",
    "moduleResolution": "bundler",
    "types": [
      "node"
    ],
    "rootDir": ".",
    "outDir": "dist",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "generated/*": [
        "./generated/*"
      ],
      "config/*": [
        "./src/config/*"
      ],
      "middleware/*": [
        "./src/middleware/*"
      ],
      "controllers/*": [
        "./src/controllers/*"
      ],
      "services/*": [
        "./src/services/*"
      ],
      "routes/*": [
        "./src/routes/*"
      ],
      "validators/*": [
        "./src/validators/*"
      ]
    },
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
  },
  "include": [
    "src",
    "lib",
    "generated",

  ]
}